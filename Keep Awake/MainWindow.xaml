<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Keep_Awake.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Keep_Awake"
    xmlns:ctc="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Keep Awake">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar (drag region) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Padding="16,0">
            <TextBlock Text="Keep Awake" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="16,0,16,16"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="4">

                <!-- Connection status -->
                <InfoBar x:Name="ConnectionInfoBar"
                         IsOpen="True" IsClosable="False"
                         Severity="Informational"
                         Title="Not connected"
                         Message="Scanning COM ports">
                    <InfoBar.ActionButton>
                        <Button Content="Rescan" Click="RescanButton_Click"/>
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- Mode -->
                <ctc:SettingsCard Header="Mode">
                    <ComboBox x:Name="ModeComboBox" MinWidth="160"
                              SelectionChanged="ModeComboBox_SelectionChanged">
                        <ComboBoxItem Content="Always Active"/>
                        <ComboBoxItem Content="Schedule"/>
                    </ComboBox>
                </ctc:SettingsCard>

                <!-- Keep Awake toggle (Always Active mode) -->
                <ctc:SettingsCard x:Name="KeepAwakeCard"
                                   Header="Keep Awake"
                                   Description="Paused">
                    <ToggleSwitch x:Name="EnableToggle"
                                  IsEnabled="False" IsOn="False"
                                  OnContent="" OffContent=""
                                  Toggled="EnableToggle_Toggled"/>
                </ctc:SettingsCard>

                <!-- Schedule (Schedule mode) -->
                <ctc:SettingsExpander x:Name="ScheduleExpander"
                                       Header="Schedule"
                                       Visibility="Collapsed">
                    <Button Content="Add" Click="AddScheduleEntry_Click"/>
                </ctc:SettingsExpander>

                <!-- Interval -->
                <ctc:SettingsCard Header="Interval">
                    <ComboBox x:Name="IntervalComboBox"
                              IsEnabled="False" MinWidth="140"
                              SelectionChanged="IntervalComboBox_SelectionChanged"/>
                </ctc:SettingsCard>

                <!-- Key -->
                <ctc:SettingsCard x:Name="KeyExpander"
                                   Header="Key"
                                   Description="Safe key – won't interfere with apps">
                    <ComboBox x:Name="KeyComboBox"
                              IsEnabled="False"
                              MinWidth="200"
                              SelectionChanged="KeyComboBox_SelectionChanged"/>
                </ctc:SettingsCard>

                <!-- Start with Windows -->
                <ctc:SettingsCard Header="Start with Windows">
                    <ToggleSwitch x:Name="StartupToggle"
                                  OnContent="" OffContent=""
                                  Toggled="Startup_Changed"/>
                </ctc:SettingsCard>

                <!-- Minimize to tray on close -->
                <ctc:SettingsCard Header="Minimize to tray on close">
                    <ToggleSwitch x:Name="MinimizeOnCloseToggle"
                                  OnContent="" OffContent=""
                                  Toggled="MinimizeOnClose_Changed"/>
                </ctc:SettingsCard>

                <!-- Activity -->
                <ctc:SettingsCard Header="Activity">
                    <TextBlock x:Name="ActivityLabel"
                               Text="Waiting for connection…"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               MaxWidth="200"/>
                </ctc:SettingsCard>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
